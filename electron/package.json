{
  "name": "vowcut",
  "version": "1.0.0",
  "description": "VowCut — local wedding highlight generator",
  "main": "build/main/main.js",
  "scripts": {
    "dev": "concurrently \"tsc -w -p tsconfig.json\" \"electron .\"",
    "build": "tsc -p tsconfig.json",
    "start": "electron .",
    "prebuild": "bash ../scripts/build_backend.sh",
    "package:mac": "electron-builder --mac",
    "package:win": "electron-builder --win"
  },
  "dependencies": {
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/node": "^20.0.0",
    "concurrently": "^8.2.0",
    "electron": "^31.0.0",
    "electron-builder": "^24.0.0",
    "typescript": "^5.5.0"
  },
  "build": {
    "appId": "com.vowcut.app",
    "productName": "VowCut",
    "directories": {
      "output": "dist"
    },
    "files": [
      "build/**/*",
      "renderer/**/*",
      "node_modules/**/*"
    ],
    "extraResources": [
      { "from": "build/python", "to": "python",  "filter": ["**/*"] },
      { "from": "build/ffmpeg",  "to": "ffmpeg",  "filter": ["**/*"] },
      { "from": "../backend",    "to": "backend",  "filter": ["**/*", "!tests/**", "!**/__pycache__/**"] }
    ],
    "mac": {
      "category": "public.app-category.video",
      "target": ["dmg", "zip"]
    },
    "win": {
      "target": ["nsis"]
    }
  }
}
